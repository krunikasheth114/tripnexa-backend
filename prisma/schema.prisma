generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum Status {
 DRAFT
  ACTIVE
  INACTIVE
  DELETED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum TransferType {
  AIRPORT_PICKUP
  AIRPORT_DROP
  RAILWAY_PICKUP
  RAILWAY_DROP
  HOTEL_TRANSFER
  SIGHTSEEING_TRANSFER
  PRIVATE_CAB
  VOLVO_BUS
}

enum ActivityType {
  ADVENTURE
  SIGHTSEEING
  TREKKING
  WATERSPORT
  RELAXATION
  CAMPFIRE
  SHOPPING
  BOATING
  SAFARI
}

//////////////////////////////////////
// DESTINATION
//////////////////////////////////////

model Destination {
  id            Int       @id @default(autoincrement())

  name          String

  slug          String?    @unique

  type          String?

  description   String?

  seasonalTags  String[]  @default([])

  status        Status    @default(ACTIVE)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  packages      Package[]

  gallery       Gallery[]
}

//////////////////////////////////////
// PACKAGE
//////////////////////////////////////

model Package {
  id                 Int       @id @default(autoincrement())

  destinationId      Int

  title              String

  slug               String?    @unique

  description        String?

  price              Float

  discountPrice      Float?

  days               Int

  nights             Int

  accommodationType  String?

  tags               String[]  @default([])

  extraInclusions    String[]  @default([])

  extraExclusions    String[]  @default([])

  status             Status    @default(ACTIVE)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  destination        Destination @relation(fields: [destinationId], references: [id])

  itineraries        Itinerary[]

  gallery            Gallery[]

  @@index([destinationId])
}

//////////////////////////////////////
// ITINERARY (DAY WISE)
//////////////////////////////////////

model Itinerary {
  id               Int       @id @default(autoincrement())

  packageId        Int

  dayNumber        Int

  dayTitle         String?

  description      String?

  status           Status    @default(ACTIVE)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  package          Package @relation(fields: [packageId], references: [id])

  hotels           ItineraryHotel[]

  meals            ItineraryMeal[]

  transfers        ItineraryTransfer[]

  activities       ItineraryActivity[]

  gallery          Gallery[]

  @@unique([packageId, dayNumber])

  @@index([packageId])
}

//////////////////////////////////////
// HOTEL MASTER
//////////////////////////////////////

model Hotel {
  id               Int       @id @default(autoincrement())

  name             String

  city             String?

  address          String?

  starRating       Int?

  description      String?

  status           Status    @default(ACTIVE)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itineraryHotels  ItineraryHotel[]
}

//////////////////////////////////////
// ITINERARY HOTEL
//////////////////////////////////////

model ItineraryHotel {
  id              Int       @id @default(autoincrement())

  itineraryId     Int

  hotelId         Int

  checkIn         Boolean   @default(false)

  checkOut        Boolean   @default(false)

  roomType        String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary       Itinerary @relation(fields: [itineraryId], references: [id])

  hotel           Hotel @relation(fields: [hotelId], references: [id])

  @@index([itineraryId])

  @@index([hotelId])
}

//////////////////////////////////////
// ITINERARY ACTIVITY
//////////////////////////////////////

model ItineraryActivity {
  id              Int       @id @default(autoincrement())

  itineraryId     Int

  activityType    ActivityType

  title           String?

  description     String?

  startTime       DateTime?

  endTime         DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary       Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
}

//////////////////////////////////////
// ITINERARY TRANSFER
//////////////////////////////////////

model ItineraryTransfer {
  id               Int       @id @default(autoincrement())

  itineraryId      Int

  transferType     TransferType

  pickupLocation   String?

  dropLocation     String?

  pickupTime       DateTime?

  dropTime         DateTime?

  notes            String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary        Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
}

//////////////////////////////////////
// ITINERARY MEALS
//////////////////////////////////////

model ItineraryMeal {
  id            Int       @id @default(autoincrement())

  itineraryId   Int

  mealType      MealType

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary     Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])

  @@unique([itineraryId, mealType])
}

model Gallery {
  id        Int      @id @default(autoincrement())
  url       String
  position  Int?

  // relations (only one should be set)
  destinationId Int?
  packageId     Int?
  itineraryId   Int?

  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // relations
  destination Destination? @relation(fields: [destinationId], references: [id])
  package     Package?     @relation(fields: [packageId], references: [id])
  itinerary   Itinerary?   @relation(fields: [itineraryId], references: [id])

  @@index([destinationId])
  @@index([packageId])
  @@index([itineraryId])
}