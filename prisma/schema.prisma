generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum Status {
  DRAFT
  ACTIVE
  INACTIVE
  DELETED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum MealPlan {
  ROOM_ONLY
  BREAKFAST_ONLY
  HALF_BOARD
  FULL_BOARD
  ALL_INCLUSIVE
}

enum TransferType {
  AIRPORT_PICKUP
  AIRPORT_DROP
  RAILWAY_PICKUP
  RAILWAY_DROP
  HOTEL_TRANSFER
  SIGHTSEEING_TRANSFER
  PRIVATE_CAB
  VOLVO_BUS
}

enum ActivityType {
  ADVENTURE
  SIGHTSEEING
  TREKKING
  WATERSPORT
  RELAXATION
  CAMPFIRE
  SHOPPING
  BOATING
  SAFARI
}

enum BookingType {
  PACKAGE
  HOTEL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  REFUNDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

//////////////////////////////////////
// DESTINATION
//////////////////////////////////////

model Destination {
  id               Int      @id @default(autoincrement())

  name             String

  slug             String?  @unique

  type             String?

  parentId         Int?

  description      String?

  seasonalTags     String[] @default([])

  formattedAddress String?
  latitude         Float?
  longitude        Float?
  placeId          String?

  status           Status   @default(ACTIVE)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  parent           Destination?  @relation("DestHierarchy", fields: [parentId], references: [id])

  children         Destination[] @relation("DestHierarchy")

  packages         Package[]

  hotels           Hotel[]

  itineraries      Itinerary[]

  gallery          Gallery[]

  @@index([parentId])
}

//////////////////////////////////////
// PACKAGE
//////////////////////////////////////

model Package {
  id                 Int      @id @default(autoincrement())

  destinationId      Int

  title              String

  slug               String?  @unique

  description        String?

  price              Float

  discountPrice      Float?

  days               Int

  nights             Int

  tags               String[] @default([])

  inclusions         Json?

  exclusions         Json?

  featured           Boolean  @default(false)

  primaryHotelId     Int?

  status             Status   @default(ACTIVE)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  destination        Destination @relation(fields: [destinationId], references: [id])

  primaryHotel       Hotel?      @relation("PackagePrimaryHotel", fields: [primaryHotelId], references: [id])

  itineraries        Itinerary[]

  gallery            Gallery[]

  bookings           Booking[]

  @@index([destinationId])

  @@index([primaryHotelId])
}

//////////////////////////////////////
// ITINERARY
//////////////////////////////////////

model Itinerary {
  id               Int      @id @default(autoincrement())

  packageId        Int

  destinationId    Int?

  dayNumber        Int

  dayTitle         String?

  description      String?

  status           Status   @default(ACTIVE)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  package          Package      @relation(fields: [packageId], references: [id])

  destination      Destination? @relation(fields: [destinationId], references: [id])

  hotels           ItineraryHotel[]

  meals            ItineraryMeal[]

  transfers        ItineraryTransfer[]

  activities       ItineraryActivity[]

  gallery          Gallery[]

  @@unique([packageId, dayNumber])

  @@index([packageId])

  @@index([destinationId])
}

//////////////////////////////////////
// HOTEL
//////////////////////////////////////

model Hotel {
  id               Int      @id @default(autoincrement())

  name             String

  city             String?

  address          String?

  starRating       Int?

  perNightPrice    Float?

  description      String?

  // Booking configuration (admin-set, used in web booking UI)
  minNights        Int?     @default(1)
  maxRooms         Int?
  maxGuests        Int?
  availableMeals   String[] @default([])   // subset of MealPlan values

  destinationId    Int?

  status           Status   @default(ACTIVE)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  destination      Destination? @relation(fields: [destinationId], references: [id])

  rooms            Room[]

  itineraryHotels  ItineraryHotel[]

  packagesPrimary  Package[]    @relation("PackagePrimaryHotel")

  bookings         Booking[]

  gallery          Gallery[]

  @@index([destinationId])
}

//////////////////////////////////////
// ROOM
//////////////////////////////////////

model Room {
  id               Int      @id @default(autoincrement())

  hotelId          Int

  name             String

  description      String?

  pricePerNight    Float

  maxAdults        Int

  maxChildren      Int

  totalRooms       Int

  status           Status   @default(ACTIVE)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  hotel            Hotel @relation(fields: [hotelId], references: [id])

  bookingRooms     BookingRoom[]

  @@index([hotelId])
}

//////////////////////////////////////
// ITINERARY HOTEL
//////////////////////////////////////

model ItineraryHotel {
  id              Int      @id @default(autoincrement())

  itineraryId     Int

  hotelId         Int

  checkIn         Boolean  @default(false)

  checkOut        Boolean  @default(false)

  roomType        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary       Itinerary @relation(fields: [itineraryId], references: [id])

  hotel           Hotel @relation(fields: [hotelId], references: [id])

  @@index([itineraryId])

  @@index([hotelId])
}

//////////////////////////////////////
// ITINERARY ACTIVITY
//////////////////////////////////////

model ItineraryActivity {
  id              Int          @id @default(autoincrement())

  itineraryId     Int

  activityType    ActivityType

  title           String?

  description     String?

  startTime       DateTime?

  endTime         DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary       Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
}

//////////////////////////////////////
// ITINERARY TRANSFER
//////////////////////////////////////

model ItineraryTransfer {
  id               Int           @id @default(autoincrement())

  itineraryId      Int

  transferType     TransferType

  pickupLocation   String?

  dropLocation     String?

  pickupTime       DateTime?

  dropTime         DateTime?

  notes            String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary        Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
}

//////////////////////////////////////
// ITINERARY MEALS
//////////////////////////////////////

model ItineraryMeal {
  id            Int       @id @default(autoincrement())

  itineraryId   Int

  mealType      MealType

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary     Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])

  @@unique([itineraryId, mealType])
}

//////////////////////////////////////
// GALLERY
//////////////////////////////////////

model Gallery {
  id             Int      @id @default(autoincrement())

  url            String

  position       Int?

  destinationId  Int?
  packageId      Int?
  itineraryId    Int?
  hotelId        Int?

  status         Status   @default(ACTIVE)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  destination    Destination? @relation(fields: [destinationId], references: [id])

  package        Package?     @relation(fields: [packageId], references: [id])

  itinerary      Itinerary?   @relation(fields: [itineraryId], references: [id])

  hotel          Hotel?       @relation(fields: [hotelId], references: [id])

  @@index([destinationId])

  @@index([packageId])

  @@index([itineraryId])

  @@index([hotelId])
}

//////////////////////////////////////
// USER
//////////////////////////////////////

model User {
  id             Int      @id @default(autoincrement())

  name           String

  email          String   @unique

  phone          String?

  password       String?

  status         Status   @default(ACTIVE)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  bookings       Booking[]
}

//////////////////////////////////////
// BOOKING
//////////////////////////////////////

model Booking {
  id               Int            @id @default(autoincrement())

  bookingNumber    String         @unique

  bookingType      BookingType    @default(PACKAGE)

  userId           Int

  packageId        Int?

  hotelId          Int?

  checkInDate      DateTime?

  checkOutDate     DateTime?

  totalNights      Int?

  totalRooms       Int?     @default(1)

  meals            String[] @default([])   // hotel meal plan selections

  travelDate       DateTime?

  totalGuests      Int

  totalAmount      Float

  paidAmount       Float          @default(0)

  remainingAmount  Float

  bookingStatus    BookingStatus  @default(PENDING)

  paymentStatus    PaymentStatus  @default(PENDING)

  specialRequest   String?

  createdAt        DateTime       @default(now())

  updatedAt        DateTime       @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  user             User      @relation(fields: [userId], references: [id])

  package          Package?  @relation(fields: [packageId], references: [id])

  hotel            Hotel?    @relation(fields: [hotelId], references: [id])

  guests           BookingGuest[]

  payments         Payment[]

  bookingRooms     BookingRoom[]

  @@index([userId])

  @@index([packageId])

  @@index([hotelId])
}

//////////////////////////////////////
// BOOKING ROOM
//////////////////////////////////////

model BookingRoom {
  id               Int       @id @default(autoincrement())

  bookingId        Int

  roomId           Int

  mealPlan         MealPlan?

  quantity         Int

  adults           Int

  children         Int

  pricePerNight    Float

  totalNights      Int

  totalAmount      Float

  createdAt        DateTime @default(now())

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  booking          Booking @relation(fields: [bookingId], references: [id])

  room             Room @relation(fields: [roomId], references: [id])

  @@index([bookingId])

  @@index([roomId])
}

//////////////////////////////////////
// BOOKING GUEST
//////////////////////////////////////

model BookingGuest {
  id               Int      @id @default(autoincrement())

  bookingId        Int

  firstName        String

  lastName         String?

  age              Int?

  gender           Gender?

  phone            String?

  email            String?

  passportNumber   String?

  nationality      String?

  createdAt        DateTime @default(now())

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  booking          Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

//////////////////////////////////////
// PAYMENT
//////////////////////////////////////

model Payment {
  id               Int            @id @default(autoincrement())

  bookingId        Int

  transactionId    String?

  paymentGateway   String?

  paymentMethod    String?

  amount           Float

  currency         String         @default("INR")

  paymentStatus    PaymentStatus  @default(PENDING)

  paidAt           DateTime?

  createdAt        DateTime       @default(now())

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  booking          Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}