generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum Status {
 DRAFT
  ACTIVE
  INACTIVE
  DELETED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum TransferType {
  AIRPORT_PICKUP
  AIRPORT_DROP
  RAILWAY_PICKUP
  RAILWAY_DROP
  HOTEL_TRANSFER
  SIGHTSEEING_TRANSFER
  PRIVATE_CAB
  VOLVO_BUS
}

enum ActivityType {
  ADVENTURE
  SIGHTSEEING
  TREKKING
  WATERSPORT
  RELAXATION
  CAMPFIRE
  SHOPPING
  BOATING
  SAFARI
}


enum BookingType {
  PACKAGE
  HOTEL
}

//////////////////////////////////////
// DESTINATION
//////////////////////////////////////

model Destination {
  id               Int       @id @default(autoincrement())

  name             String

  slug             String?   @unique

  // Category of destination: WILDLIFE | HERITAGE | RELIGIOUS | BEACH | ADVENTURE | CULTURAL | CITY | REGION
  type             String?

  // Hierarchy: null = state-level, filled = child destination (belongs to a state)
  parentId         Int?

  description      String?

  seasonalTags     String[]  @default([])

  // Google Maps / Places
  formattedAddress String?
  latitude         Float?
  longitude        Float?
  placeId          String?

  status           Status    @default(ACTIVE)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  parent           Destination?  @relation("DestHierarchy", fields: [parentId], references: [id])
  children         Destination[] @relation("DestHierarchy")

  packages         Package[]

  gallery          Gallery[]

  hotels           Hotel[]

  itineraries      Itinerary[]

  @@index([parentId])
}

//////////////////////////////////////
// PACKAGE
//////////////////////////////////////

model Package {
  id                 Int       @id @default(autoincrement())

  destinationId      Int

  title              String

  slug               String?    @unique

  description        String?

  price              Float

  discountPrice      Float?

  days               Int

  nights             Int

  tags               String[]  @default([])

  // JSON shape: { meals?: string[], accommodation?: string[], transport?: string[], activities?: true, ... }
  inclusions         Json?

  exclusions         Json?

  featured           Boolean   @default(false)

  primaryHotelId     Int?

  status             Status    @default(ACTIVE)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  destination        Destination @relation(fields: [destinationId], references: [id])

  primaryHotel       Hotel?      @relation("PackagePrimaryHotel", fields: [primaryHotelId], references: [id])

  itineraries        Itinerary[]

  gallery            Gallery[]

  bookings           Booking[]

  @@index([destinationId])
  @@index([primaryHotelId])
}

//////////////////////////////////////
// ITINERARY (DAY WISE)
//////////////////////////////////////

model Itinerary {
  id               Int       @id @default(autoincrement())

  packageId        Int

  // Which destination this day is in (for multi-destination packages)
  destinationId    Int?

  dayNumber        Int

  dayTitle         String?

  description      String?

  status           Status    @default(ACTIVE)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  package          Package      @relation(fields: [packageId], references: [id])

  destination      Destination? @relation(fields: [destinationId], references: [id])

  hotels           ItineraryHotel[]

  meals            ItineraryMeal[]

  transfers        ItineraryTransfer[]

  activities       ItineraryActivity[]

  gallery          Gallery[]

  @@unique([packageId, dayNumber])

  @@index([packageId])
  @@index([destinationId])
}

//////////////////////////////////////
// HOTEL MASTER
//////////////////////////////////////

model Hotel {
  id               Int       @id @default(autoincrement())

  name             String

  city             String?

  address          String?

  starRating       Int?

  perNightPrice    Float?

  description      String?

  destinationId    Int?

  status           Status    @default(ACTIVE)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  destination      Destination? @relation(fields: [destinationId], references: [id])

  itineraryHotels  ItineraryHotel[]

  packagesPrimary  Package[]    @relation("PackagePrimaryHotel")

  gallery          Gallery[]
  bookings         Booking[]

  @@index([destinationId])
}

//////////////////////////////////////
// ITINERARY HOTEL
//////////////////////////////////////

model ItineraryHotel {
  id              Int       @id @default(autoincrement())

  itineraryId     Int

  hotelId         Int

  checkIn         Boolean   @default(false)

  checkOut        Boolean   @default(false)

  roomType        String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary       Itinerary @relation(fields: [itineraryId], references: [id])

  hotel           Hotel @relation(fields: [hotelId], references: [id])

  @@index([itineraryId])

  @@index([hotelId])
}

//////////////////////////////////////
// ITINERARY ACTIVITY
//////////////////////////////////////

model ItineraryActivity {
  id              Int       @id @default(autoincrement())

  itineraryId     Int

  activityType    ActivityType

  title           String?

  description     String?

  startTime       DateTime?

  endTime         DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary       Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
}

//////////////////////////////////////
// ITINERARY TRANSFER
//////////////////////////////////////

model ItineraryTransfer {
  id               Int       @id @default(autoincrement())

  itineraryId      Int

  transferType     TransferType

  pickupLocation   String?

  dropLocation     String?

  pickupTime       DateTime?

  dropTime         DateTime?

  notes            String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary        Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])
}

//////////////////////////////////////
// ITINERARY MEALS
//////////////////////////////////////

model ItineraryMeal {
  id            Int       @id @default(autoincrement())

  itineraryId   Int

  mealType      MealType

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  itinerary     Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([itineraryId])

  @@unique([itineraryId, mealType])
}

model Gallery {
  id        Int      @id @default(autoincrement())
  url       String
  position  Int?

  // relations (only one should be set)
  destinationId Int?
  packageId     Int?
  itineraryId   Int?
  hotelId       Int?

  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // relations
  destination Destination? @relation(fields: [destinationId], references: [id])
  package     Package?     @relation(fields: [packageId], references: [id])
  itinerary   Itinerary?   @relation(fields: [itineraryId], references: [id])
  hotel       Hotel?       @relation(fields: [hotelId], references: [id])

  @@index([destinationId])
  @@index([packageId])
  @@index([itineraryId])
  @@index([hotelId])
}

//////////////////////////////////////
// USER & AUTH
//////////////////////////////////////

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  password  String?
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
}

//////////////////////////////////////
// BOOKING
//////////////////////////////////////

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  REFUNDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Booking {
  id              Int           @id @default(autoincrement())

  bookingNumber   String        @unique

bookingType       BookingType @default(PACKAGE)

  userId          Int

  // Optional Relations
  packageId       Int?
  hotelId         Int?

  // Hotel booking fields
  checkInDate     DateTime?
  checkOutDate    DateTime?
  totalRooms      Int?

  // Common fields
  travelDate      DateTime?
  totalGuests     Int
  totalAmount     Float
  paidAmount      Float         @default(0)
  remainingAmount Float

  bookingStatus   BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)

  specialRequest  String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  //////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////

  user            User      @relation(fields: [userId], references: [id])

  package         Package?  @relation(fields: [packageId], references: [id])

  hotel           Hotel?    @relation(fields: [hotelId], references: [id])

  guests          BookingGuest[]

  payments        Payment[]

  @@index([userId])

  @@index([packageId])

  @@index([hotelId])
}

model BookingGuest {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  firstName      String
  lastName       String?
  age            Int?
  gender         Gender?
  phone          String?
  email          String?
  passportNumber String?
  nationality    String?
  createdAt      DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Payment {
  id             Int           @id @default(autoincrement())
  bookingId      Int
  transactionId  String?
  paymentGateway String?
  paymentMethod  String?
  amount         Float
  currency       String        @default("INR")
  paymentStatus  PaymentStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}